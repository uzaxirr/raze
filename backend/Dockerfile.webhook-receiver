FROM python:3.12-slim

WORKDIR /app

# Copy requirements
COPY backend/services/webhook_receiver/requirements.txt ./

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend code (needed for db models, shared modules)
COPY backend/ .

# Set Python path
ENV PYTHONPATH=/app

# Expose port
EXPOSE 8010

# Run the webhook receiver
WORKDIR /app/services/webhook_receiver
CMD ["python", "main.py"]
